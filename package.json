{
  "name": "zeiterfassung",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm run dev -w apps/api",
    "api:build": "npm run build -w apps/api",
    "web:dev": "npm run dev -w apps/web",
    "web:build": "npm run build -w apps/web",
    "shared:build": "npm run build -w packages/shared",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:generate": "npm run db:generate -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "mobile:build": "npm run build -w apps/mobile",
    "mobile:android": "npm run open:android -w apps/mobile",
    "mobile:ios": "npm run open:ios -w apps/mobile"
  },
  "engines": {
    "node": ">=20"
  }
}
