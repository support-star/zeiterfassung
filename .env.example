# ═══════════════════════════════════════════════════════════════
# Zeiterfassung – Umgebungsvariablen
# Diese Datei kopieren: cp .env.example .env
# Dann alle Werte anpassen!
# ═══════════════════════════════════════════════════════════════

# ── Domain ────────────────────────────────────────────────────
DOMAIN=zeiterfassung.deine-domain.de

# ── Datenbank ─────────────────────────────────────────────────
POSTGRES_USER=zeiterfassung
POSTGRES_PASSWORD=SICHERES_PASSWORT_HIER
POSTGRES_DB=zeiterfassung

# ── JWT Auth ──────────────────────────────────────────────────
# Generieren: openssl rand -hex 64
JWT_SECRET=HIER_LANGEN_ZUFALLSSTRING_EINTRAGEN
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# ── E-Mail (für Benachrichtigungen) ───────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=deine@gmail.com
# Gmail: Konto → Sicherheit → 2FA → App-Passwörter
MAIL_PASS=xxxx-xxxx-xxxx-xxxx
MAIL_FROM=Zeiterfassung <noreply@deine-domain.de>
